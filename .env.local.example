# Copy this to .env.local and fill in your values

# MongoDB connection string (required)
# Local: mongodb://localhost:27017/chore-scheduler
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/chore-scheduler
MONGODB_URI=mongodb://localhost:27017/chore-scheduler

# Next.js public URL (optional, defaults to http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000
